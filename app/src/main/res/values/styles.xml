<?xml version="1.0" encoding="utf-8"?>
<resources>
    

    <style name="NumButton" parent="Widget.AppCompat.Button">
        <item name="android:layout_width">70dp</item>
        <item name="android:layout_height">70dp</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">#000000</item>
<!--        <item name="android:background">@drawable/input_num_shape</item>-->
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="AppLockPinKey">
        <item name="android:layout_width">66dp</item>
        <item name="android:layout_height">66dp</item>
        <item name="android:background">@drawable/pin_key_background</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#1D2959</item>
        <item name="android:textSize">32sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
</resources>
